  <property name="styleSheet">
   <string notr="true">/* ==========================================================
   Maya → ComfyUI  —  Dark Theme (VSCode-inspired)
   ========================================================== */

/* ---- Base ------------------------------------------------ */
QWidget {
    background-color: #1E1E1E;
    color: #D4D4D4;
    font-size: 10pt;
    font-family: &quot;Segoe UI&quot;, &quot;Pretendard&quot;, sans-serif;
}

/* ---- Frame / Panel --------------------------------------- */
QFrame {
    background-color: #252526;
    border: none;
    border-radius: 5px;
}

QFrame#main_F {
    background-color: #1E1E1E;
    border: none;
}

/* ---- GroupBox -------------------------------------------- */
QGroupBox {
    background-color: #252526;
    border: 1px solid #2D2D30;
    border-radius: 6px;
    margin-top: 14px;
    padding: 10px 6px 6px 6px;
    font-weight: bold;
    color: #9CDCFE;
}

QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    left: 10px;
    padding: 0 6px;
    background-color: #252526;
    color: #9CDCFE;
}

/* ---- Label ----------------------------------------------- */
QLabel {
    background-color: transparent;
    border: none;
    color: #CCCCCC;
}

/* PreviewLabel (custom widget) */
PreviewLabel {
    background-color: #141414;
    border: 1px solid #2D2D30;
    border-radius: 4px;
    color: #6A6A6A;
}

/* ---- LineEdit / TextEdit --------------------------------- */
QLineEdit, QPlainTextEdit, QTextBrowser, QTextEdit {
    background-color: #181818;
    border: 1px solid #3C3C3C;
    border-radius: 4px;
    padding: 5px;
    color: #D4D4D4;
    selection-background-color: #094771;
}

QLineEdit:focus, QPlainTextEdit:focus, QTextBrowser:focus, QTextEdit:focus {
    border: 1px solid #007ACC;
}

QLineEdit:disabled, QPlainTextEdit:disabled {
    background-color: #1A1A1A;
    color: #5A5A5A;
    border: 1px solid #2A2A2A;
}

/* ---- Button ---------------------------------------------- */
QPushButton {
    background-color: #0E639C;
    color: #FFFFFF;
    border: none;
    border-radius: 4px;
    padding: 6px 12px;
    font-weight: bold;
}

QPushButton:hover {
    background-color: #1177BB;
}

QPushButton:pressed {
    background-color: #094771;
}

QPushButton:disabled {
    background-color: #2A2A2A;
    color: #5A5A5A;
}

/* primary action button — 생성 버튼 강조용 */
QPushButton#createImage_Btn {
    background-color: #16825D;
    font-size: 11pt;
    font-weight: bold;
    padding: 10px 16px;
}

QPushButton#createImage_Btn:hover {
    background-color: #1E9B70;
}

QPushButton#createImage_Btn:pressed {
    background-color: #0F6A4A;
}

/* tool / icon-only button — 새로고침·폴더 열기 같은 작은 버튼 */
QPushButton#reloadMayaCamera_Btn,
QPushButton#reloadComfyui_Btn,
QPushButton#reloadCheckPoint_Btn,
QPushButton#reloadSampler_Btn,
QPushButton#openPreviewImage_Btn,
QPushButton#openPreviewImageFolder_Btn,
QPushButton#reloadPreviewImage_Btn,
QPushButton#openCreateImage_Btn,
QPushButton#openCreateImageFolder_Btn,
QPushButton#reloadCreateImage_Btn,
QPushButton#manual_Btn {
    background-color: #2D2D30;
    color: #CCCCCC;
    padding: 4px 8px;
    min-width: 24px;
}

QPushButton#reloadMayaCamera_Btn:hover,
QPushButton#reloadComfyui_Btn:hover,
QPushButton#reloadCheckPoint_Btn:hover,
QPushButton#reloadSampler_Btn:hover,
QPushButton#openPreviewImage_Btn:hover,
QPushButton#openPreviewImageFolder_Btn:hover,
QPushButton#reloadPreviewImage_Btn:hover,
QPushButton#openCreateImage_Btn:hover,
QPushButton#openCreateImageFolder_Btn:hover,
QPushButton#reloadCreateImage_Btn:hover,
QPushButton#manual_Btn:hover {
    background-color: #3E3E42;
    color: #FFFFFF;
}

/* ---- ComboBox -------------------------------------------- */
QComboBox {
    background-color: #3C3C3C;
    border: 1px solid #3C3C3C;
    border-radius: 4px;
    padding: 4px 8px;
    color: #CCCCCC;
    min-height: 18px;
}

QComboBox:hover {
    border: 1px solid #007ACC;
}

QComboBox:focus {
    border: 1px solid #007ACC;
}

QComboBox::drop-down {
    border: none;
    width: 20px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid #CCCCCC;
    width: 0;
    height: 0;
    margin-right: 6px;
}

QComboBox QAbstractItemView {
    background-color: #252526;
    border: 1px solid #3C3C3C;
    color: #D4D4D4;
    selection-background-color: #094771;
    selection-color: #FFFFFF;
    outline: none;
}

/* ---- SpinBox --------------------------------------------- */
QSpinBox, QDoubleSpinBox {
    background-color: #181818;
    border: 1px solid #3C3C3C;
    border-radius: 4px;
    padding: 3px 6px;
    color: #D4D4D4;
    selection-background-color: #094771;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #007ACC;
}

QSpinBox:disabled, QDoubleSpinBox:disabled {
    background-color: #1A1A1A;
    color: #5A5A5A;
}

QSpinBox::up-button, QDoubleSpinBox::up-button {
    background-color: #2D2D30;
    border: none;
    border-top-right-radius: 3px;
    width: 16px;
}

QSpinBox::down-button, QDoubleSpinBox::down-button {
    background-color: #2D2D30;
    border: none;
    border-bottom-right-radius: 3px;
    width: 16px;
}

QSpinBox::up-button:hover, QDoubleSpinBox::up-button:hover,
QSpinBox::down-button:hover, QDoubleSpinBox::down-button:hover {
    background-color: #3E3E42;
}

QSpinBox::up-arrow, QDoubleSpinBox::up-arrow {
    image: none;
    border-left: 3px solid transparent;
    border-right: 3px solid transparent;
    border-bottom: 4px solid #CCCCCC;
    width: 0;
    height: 0;
}

QSpinBox::down-arrow, QDoubleSpinBox::down-arrow {
    image: none;
    border-left: 3px solid transparent;
    border-right: 3px solid transparent;
    border-top: 4px solid #CCCCCC;
    width: 0;
    height: 0;
}

/* ---- TabWidget ------------------------------------------- */
QTabWidget::pane {
    background-color: #252526;
    border: 1px solid #2D2D30;
    border-radius: 4px;
    top: -1px;
}

QTabBar::tab {
    background-color: #2D2D30;
    color: #969696;
    padding: 6px 14px;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
    margin-right: 2px;
    font-weight: bold;
}

QTabBar::tab:hover {
    background-color: #3E3E42;
    color: #CCCCCC;
}

QTabBar::tab:selected {
    background-color: #252526;
    color: #FFFFFF;
    border-bottom: 2px solid #007ACC;
}

/* ---- ListWidget (gallery) -------------------------------- */
QListWidget {
    background-color: #181818;
    border: 1px solid #2D2D30;
    border-radius: 4px;
    padding: 4px;
    color: #D4D4D4;
    outline: none;
}

QListWidget::item {
    background-color: #252526;
    border: 1px solid transparent;
    border-radius: 4px;
    padding: 4px;
    margin: 2px;
    color: #CCCCCC;
}

QListWidget::item:hover {
    background-color: #2D2D30;
    border: 1px solid #3C3C3C;
}

QListWidget::item:selected {
    background-color: #094771;
    border: 1px solid #007ACC;
    color: #FFFFFF;
}

/* ---- ProgressBar ----------------------------------------- */
QProgressBar {
    background-color: #181818;
    border: 1px solid #2D2D30;
    border-radius: 4px;
    text-align: center;
    color: #D4D4D4;
    font-weight: bold;
    min-height: 18px;
}

QProgressBar::chunk {
    background-color: #007ACC;
    border-radius: 3px;
}

/* ---- ScrollBar ------------------------------------------- */
QScrollBar:vertical {
    background-color: #1E1E1E;
    width: 12px;
    margin: 0;
    border: none;
}

QScrollBar::handle:vertical {
    background-color: #3E3E42;
    border-radius: 5px;
    min-height: 30px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background-color: #5A5A5C;
}

QScrollBar::add-line:vertical, QScrollBar::sub-line:vertical {
    height: 0;
    border: none;
}

QScrollBar::add-page:vertical, QScrollBar::sub-page:vertical {
    background: none;
}

QScrollBar:horizontal {
    background-color: #1E1E1E;
    height: 12px;
    margin: 0;
    border: none;
}

QScrollBar::handle:horizontal {
    background-color: #3E3E42;
    border-radius: 5px;
    min-width: 30px;
    margin: 2px;
}

QScrollBar::handle:horizontal:hover {
    background-color: #5A5A5C;
}

QScrollBar::add-line:horizontal, QScrollBar::sub-line:horizontal {
    width: 0;
    border: none;
}

QScrollBar::add-page:horizontal, QScrollBar::sub-page:horizontal {
    background: none;
}

/* ---- CheckBox -------------------------------------------- */
QCheckBox {
    background-color: transparent;
    color: #CCCCCC;
    spacing: 6px;
}

QCheckBox::indicator {
    width: 14px;
    height: 14px;
    border: 1px solid #3C3C3C;
    border-radius: 3px;
    background-color: #181818;
}

QCheckBox::indicator:hover {
    border: 1px solid #007ACC;
}

QCheckBox::indicator:checked {
    background-color: #007ACC;
    border: 1px solid #007ACC;
}

/* ---- ToolTip --------------------------------------------- */
QToolTip {
    background-color: #252526;
    border: 1px solid #007ACC;
    color: #D4D4D4;
    padding: 4px 8px;
    border-radius: 3px;
}</string>
